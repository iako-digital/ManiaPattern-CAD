DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cloudpattern_cad?schema=public"
PORT=8080
CORS_ORIGIN="http://localhost:3000"

# Required in production; falls back to an insecure dev secret otherwise.
JWT_SECRET="change-me-to-a-long-random-string"

# Optional — if unset, blobService no-ops (uploads/deletes are skipped with a warning).
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="pattern-files"
